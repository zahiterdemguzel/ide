{
  "name": "claude-session-editor",
  "version": "0.1.0",
  "description": "Manage multiple interactive Claude CLI sessions with auto status + git staging",
  "author": "zahiterdemguzel",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.claude.session-editor",
    "productName": "Claude Session Editor",
    "npmRebuild": false,
    "files": [
      "index.html",
      "src/**/*",
      "assets/**/*",
      ".vscode/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable",
      "icon": "assets/icon.png"
    }
  },
  "dependencies": {
    "@highlightjs/cdn-assets": "11.11.1",
    "@homebridge/node-pty-prebuilt-multiarch": "^0.12.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
