{
  "name": "claude-session-editor",
  "version": "0.2.0",
  "description": "Manage multiple interactive Claude CLI sessions with auto status + git staging",
  "author": "zahiterdemguzel",
  "main": "src/main/index.js",
  "scripts": {
    "postinstall": "node scripts/fix-electron-signature.js",
    "prestart": "node scripts/gen-icons.js",
    "start": "electron .",
    "build": "electron-builder --win dir --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:linux": "electron-builder --linux AppImage --publish never",
    "build:android": "node scripts/build-android.mjs",
    "gen:mobile": "node scripts/gen-mobile-assets.mjs",
    "test": "node --test --test-reporter=./scripts/test-reporter.js",
    "lint": "eslint ."
  },
  "build": {
    "appId": "com.claude.session-editor",
    "productName": "Claude Session Editor",
    "npmRebuild": false,
    "onNodeModuleFile": "./build/on-node-module-file.js",
    "files": [
      "index.html",
      "src/**/*",
      "server/**/*",
      "assets/**/*",
      "!assets/icon-dev.png",
      ".vscode/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "asarUnpack": [
      "node_modules/node-llama-cpp/**",
      "node_modules/@node-llama-cpp/**",
      "node_modules/@nut-tree-fork/**"
    ],
    "win": {
      "target": "dir",
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "Development"
    }
  },
  "dependencies": {
    "@highlightjs/cdn-assets": "11.11.1",
    "@homebridge/node-pty-prebuilt-multiarch": "^0.12.0",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "node-llama-cpp": "^3.19.0",
    "paper": "^0.12.18",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.4.624",
    "qrcode-generator": "^2.0.4",
    "sql.js": "^1.14.1",
    "three": "^0.185.0",
    "ws": "^8.21.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9.39.4",
    "globals": "^15.15.0"
  }
}
