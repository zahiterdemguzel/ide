{
  "expo": {
    "name": "IDE Remote",
    "slug": "ide-remote",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "ide",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0d1117",
    "androidNavigationBar": {
      "barStyle": "light-content",
      "backgroundColor": "#161b22"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Scan the pairing QR code shown by the desktop IDE.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "package": "com.ideremote.app",
      "permissions": [
        "CAMERA",
        "REQUEST_INSTALL_PACKAGES"
      ],
      "usesCleartextTraffic": true
    },
    "plugins": [
      "expo-notifications",
      "expo-camera",
      "expo-secure-store",
      "expo-asset",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Attach a screenshot or photo to a message you send Claude.",
          "cameraPermission": "Take a photo to attach to a message you send Claude."
        }
      ]
    ]
  }
}
