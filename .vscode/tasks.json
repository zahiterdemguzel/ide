{
  // Tasks surfaced as buttons in the app's top toolbar (right of the launch
  // configs, after the separator). Each one opens an external terminal.
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install deps",
      "type": "shell",
      "command": "npm install",
      "options": { "cwd": "${workspaceFolder}" }
    },
    {
      "label": "Start app",
      "type": "shell",
      "command": "npm start",
      "options": { "cwd": "${workspaceFolder}" }
    },
    {
      "label": "Build windows",
      "type": "shell",
      "command": "npm run build",
      "options": { "cwd": "${workspaceFolder}" }
    },
    {
      "label": "Build macos",
      "type": "shell",
      "command": "npm run build:mac",
      "options": { "cwd": "${workspaceFolder}" }
    },
    {
      "label": "Run tests",
      "type": "shell",
      "command": "npm test",
      "options": { "cwd": "${workspaceFolder}" },
      "group": { "kind": "test", "isDefault": true }
    }
  ]
}
