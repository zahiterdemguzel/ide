{
  // Run configs surfaced as buttons in the app's top toolbar. Each one opens an
  // external terminal — there's no in-process debugger.
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Start IDE",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      // No --folder flag: the app starts with no project open (the recent-projects
      // picker pops up on launch), matching the real first-run experience.
      "runtimeArgs": ["start"],
      "cwd": "${workspaceFolder}",
      // Run in a real terminal so the main process's stdout/stderr is visible.
      // The default ("internalConsole") routes Electron output to the Debug
      // Console, where it mostly doesn't show up.
      "console": "integratedTerminal",
      // The desktop embeds the same backend modules (hub, relay dialer, port-forward
      // proxy), so IDE_DEBUG traces those here too — silent until remote access is on.
      "env": { "IDE_DEBUG": "*,-tunnel" },
      // Electron spawns Chromium renderer/GPU child processes. If VS Code
      // auto-attaches its debugger to them (the default), it injects an inspector
      // into the renderer and the window stops responding to clicks/keys. Attach
      // to the main process only so the app stays interactive.
      "autoAttachChildProcesses": false
    },
    {
      // The standalone relay from server/ (socket bridge only — LAN mode doesn't
      // need it; the desktop app embeds the ws server itself). Local run for
      // developing/testing relay mode; listens on PORT (default 8080).
      //
      // Debug mode: IDE_DEBUG makes server/debug.js trace every operation the
      // backend performs (sockets, rooms, protocol frames, routing decisions,
      // tunnel bytes) to this terminal. Narrow it when the log is too loud —
      // e.g. "relay,hub" for sockets + protocol only, or "*,-tunnel" to keep
      // everything but the per-chunk byte traffic of a forwarded dev server.
      "name": "Start backend (relay)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/server/index.js",
      "cwd": "${workspaceFolder}/server",
      "console": "integratedTerminal",
      "env": { "IDE_DEBUG": "*" }
    },
    {
      // Expo dev server for the companion app; open it in Expo Go on the phone.
      // Requires a one-time `npm install` in mobile/ first.
      "name": "Start mobile app",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start"],
      "cwd": "${workspaceFolder}/mobile",
      "console": "integratedTerminal"
    }
  ],
  "compounds": [
    {
      "name": "Start all (IDE + backend + mobile)",
      "configurations": ["Start IDE", "Start backend (relay)", "Start mobile app"]
    }
  ]
}
