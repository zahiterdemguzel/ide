{
  // Run configs surfaced as buttons in the app's top toolbar. Each one opens an
  // external terminal — there's no in-process debugger.
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Start IDE",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      // Open the gitignored throwaway test workspace instead of the persisted
      // last folder, so developing the IDE with the IDE doesn't have the test
      // instance fight over (or commit into) the real repo. `--` forwards the
      // flag through `npm start` to `electron .` (parsed by src/main/cli-args.js).
      "runtimeArgs": ["start", "--", "--folder", "${workspaceFolder}/.test-workspace"],
      "cwd": "${workspaceFolder}",
      // Run in a real terminal so the main process's stdout/stderr is visible.
      // The default ("internalConsole") routes Electron output to the Debug
      // Console, where it mostly doesn't show up.
      "console": "integratedTerminal",
      // Electron spawns Chromium renderer/GPU child processes. If VS Code
      // auto-attaches its debugger to them (the default), it injects an inspector
      // into the renderer and the window stops responding to clicks/keys. Attach
      // to the main process only so the app stays interactive.
      "autoAttachChildProcesses": false
    }
  ]
}
